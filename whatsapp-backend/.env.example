# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# WhatsApp Integration Choice: 'wasender' or 'meta'
WHATSAPP_PROVIDER=wasender

# =========================================================================
# Option A: WaSender API Configuration (Default for Triage Alerts)
# =========================================================================
WASENDER_API_KEY=your_wasender_api_key_here
WASENDER_URL=https://wasenderapi.com/api/send-message


# =========================================================================
# Option B: Meta WhatsApp Cloud API Configuration (For production/business)
# =========================================================================
META_ACCESS_TOKEN=your_meta_system_user_access_token_here
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
