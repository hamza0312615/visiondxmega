# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# WhatsApp Integration Choice: 'twilio' or 'meta'
WHATSAPP_PROVIDER=twilio

# =========================================================================
# Option A: Twilio Sandbox Configuration (Recommended for quick testing)
# =========================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# The sandbox sender is usually '+14155238886' unless you upgraded to a paid profile
TWILIO_FROM_NUMBER=+14155238886

# =========================================================================
# Option B: Meta WhatsApp Cloud API Configuration (For production/business)
# =========================================================================
META_ACCESS_TOKEN=your_meta_system_user_access_token_here
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
